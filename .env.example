# ===== 虾虾工厂 环境配置 =====
# 复制此文件为 .env 并修改为实际值

# 数据库
DB_USER=xiaxia
DB_PASS=xiaxia_secret_2026
DB_HOST=db
DB_NAME=xiaxia_factory

# JWT
JWT_SECRET=xiaxia-jwt-secret-key-2026

# Flask
FLASK_ENV=production
FLASK_DEBUG=0

# 限流 (requests per minute)
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute

# 告警 Webhook (钉钉/飞书/Slack)
ALERT_WEBHOOK_URL=
