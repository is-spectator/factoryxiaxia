# ===== 虾虾工厂 环境配置 =====
# 复制此文件为 .env 并修改为实际值
#
# ⚠️ 安全提示:
#   1. 生产环境 **必须** 修改下列所有密码和密钥，切勿使用默认值
#   2. .env 文件已加入 .gitignore，请勿提交到版本控制
#   3. JWT_SECRET 建议使用 `openssl rand -hex 32` 生成随机密钥

# 应用环境
# 本地开发建议使用 development
# 生产环境必须显式设置为 production
APP_ENV=development

# 数据库
DB_USER=xiaxia
MYSQL_ROOT_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_PASS=CHANGE_ME_IN_PRODUCTION
DB_HOST=db
DB_NAME=xiaxia_factory

# JWT（生产环境务必替换）
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# Agent Provider
AGENT_PROVIDER=rules
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DASHSCOPE_TEMPERATURE=0.2
DASHSCOPE_TOP_P=0.8
DASHSCOPE_MAX_TOKENS=800
DASHSCOPE_TIMEOUT_SECONDS=30
DASHSCOPE_RETRY_ATTEMPTS=1

# 对外访问地址
PUBLIC_BASE_URL=http://localhost:10088

# 允许访问 API 的前端域名，多个域名用逗号分隔
ALLOWED_ORIGINS=http://localhost:10088,http://127.0.0.1:10088

# Flask
FLASK_ENV=development
FLASK_DEBUG=0

# 限流 (requests per minute)
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
PUBLIC_CHAT_IP_LIMIT_PER_MINUTE=30
PUBLIC_CHAT_DEPLOYMENT_LIMIT_PER_MINUTE=120

# 告警 Webhook (钉钉/飞书/Slack)
ALERT_WEBHOOK_URL=

# 首次管理员初始化
# 生产环境第一次启动且系统内没有 admin 时，会自动创建一次性管理员
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_EMAIL=admin@xiaxia.factory
ADMIN_INIT_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# 前端监听端口
FRONTEND_PORT=10088

# 空空 OpenClaw 运行时
# 默认开启 docker，便于直接测试空空；如仅想跑普通机器人可改回 mock
KONGKONG_RUNTIME_MODE=docker
# 必须是宿主机绝对路径，并且 compose 会把它原样挂进 backend 容器与 OpenClaw 实例
KONGKONG_BASE_DIR=/tmp/factoryxiaxia/kongkong
# backend / frontend / OpenClaw sibling containers 共享的 Docker 网络名称
KONGKONG_DOCKER_NETWORK=xiaxia-platform
# development 建议开启，便于本机做 smoke test；production 建议关闭
KONGKONG_EXPOSE_DEBUG_PORTS=1
